# =====================================================================
# SERVER-ONLY environment variables. NEVER prefix with NEXT_PUBLIC_.
# Copy to `.env.local` in the client/ Next.js app root.
# =====================================================================

# Speech-to-Text provider (Urdu/Pashto support required).
# Expected provider: OpenAI Whisper API (or compatible).
STT_API_KEY=

# Intent parsing LLM (Gemini / Groq / OpenAI — see server/src/integrations/llm-client.ts).
LLM_PARSER_API_KEY=

# WhatsApp Cloud API (Meta) — phone number id + access token.
# WHATSAPP_API_KEY holds the permanent/system-user access token.
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# Optional — override default provider endpoints / models.
# STT_PROVIDER=openai
# STT_MODEL=whisper-1
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash

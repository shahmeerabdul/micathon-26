# =====================================================================
# SERVER-ONLY environment variables. NEVER prefix with NEXT_PUBLIC_.
# Copy this file to `client/.env.local` (Next.js reads .env.local at the
# root of the client app). All three blocks below are REQUIRED for the
# real voice pipeline to work.
# =====================================================================

# ───────────────────── Gemini (audio + intent parsing) ─────────────────
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-ai-studio-api-key

# Optional override — default is the current Gemini 3 Flash preview.
# Other valid options: gemini-2.5-flash, gemini-3-pro-preview.
GEMINI_MODEL=gemini-3-flash-preview

# ───────────────────────── MongoDB Atlas ───────────────────────────────
# Atlas connection string (Database → Connect → Drivers → Node.js).
# Format: mongodb+srv://<user>:<pwd>@<cluster>/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority

# Database name. Defaults to "khata" if not set.
MONGODB_DB=khata

# Optional: comma-separated DNS resolvers for SRV lookups.
# Useful if your ISP/router blocks _mongodb._tcp SRV queries.
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# ───────────────────── Twilio WhatsApp (outbound messages) ─────────────
# Used by the voice pipeline to send:
#   1. Welcome messages to brand-new customers.
#   2. Receipts after every purchase.
#   3. Bill summaries on demand.
# If these are blank the voice pipeline still works — Twilio calls are
# skipped with a warning.
#
# Get credentials from https://console.twilio.com (Account SID + Auth Token).
# For local testing, activate the WhatsApp sandbox and use its "from" number.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_ENABLED=true

# Legacy WhatsApp Cloud API vars — kept for the original outbound-message
# action. Safe to leave blank when using Twilio.
# WHATSAPP_API_KEY=
# WHATSAPP_PHONE_NUMBER_ID=

# ───────────────────── STT fallback (optional) ─────────────────────────
# Used only if we decide to support a non-Gemini STT path. Leave blank
# for the MVP — Gemini handles audio natively.
# STT_API_KEY=
